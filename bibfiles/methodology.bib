	pages = {2115--2124},
	publisher = {PMLR},
	series = {Proceedings of Machine Learning Research},
	title = {The non-parametric bootstrap and spectral analysis in moderate and high-dimension},
	url = {https://proceedings.mlr.press/v89/karoui19a.html},
	volume = {89},
	year = {2019},
	bdsk-url-1 = {https://proceedings.mlr.press/v89/karoui19a.html}}

