@phdthesis{purdom_multivariate_2006,
	abstract = {Increasingly, current knowledge of a biological process is summarized in the form of a graph or{\textbackslash}na network. However, graphical structures are difficult to incorporate into a standard data analysis.{\textbackslash}nIn particular, it is difficult to relate the information in a graph to new experimental data. Various{\textbackslash}nauthors have suggested kernel approaches to these problems. Such kernel methods adapt classical{\textbackslash}nmultivariate statistical techniques for more general types of data. Rather than require numerical{\textbackslash}ndescription of the data, kernel techniques require only a particular type of measure of similarity{\textbackslash}nbetween objects. For biological graphs, different authors have used a measure of similarity between{\textbackslash}nnodes of a graph to analyze graphs with kernel techniques. However, the kernel methods in use only{\textbackslash}ngenerally describe the relationship between the graph and the experiment without being explicitly{\textbackslash}npredictive; in particular, they derive from the classical technique of Canonical Correlation Analysis{\textbackslash}n(CCA).{\textbackslash}nIn this work, we turn instead to explicitly predictive multivariate regression techniques. We{\textbackslash}nextend multivariate regression to the kernel framework and show that this provides a method more{\textbackslash}nappropriate for these tasks, which are generally predictive in nature. In doing so, we also show{\textbackslash}nhow the CCA and regression framework are related through regularization of the problem. We{\textbackslash}nillustrate how these kernel techniques are equivalent to classical statistical techniques, if the ``data''{\textbackslash}nfor an observation consists of the similarity of the observation to the training set. This is a different{\textbackslash}ninterpretation of the kernel techniques and can be more convenient for those already familiar with{\textbackslash}nclassical statistics.{\textbackslash}nWe demonstrate our techniques for two different types of graphs: 1) a yeast metabolic network{\textbackslash}nand 2) a phylogenetic tree. For the metabolic network, we use a network and related experimental{\textbackslash}ndata that has been previously analyzed the literature using kernel methods. For the phylogenetic tree, we analyze ecological data collected on bacteria and their estimated phylogenetic tree. For{\textbackslash}nthe latter set of data, we suggest a different type of similarity appropriate for phylogenetic trees,{\textbackslash}nand we connect this type of analysis to others in the literature.{\textbackslash}n},
	author = {Purdom, Elizabeth},
	copyright = {All rights reserved},
	date-modified = {2024-07-09 13:42:35 -0700},
	keywords = {book},
	note = {Publication Title: PhD},
	school = {Stanford University},
	title = {Multivariate {Kernel} {Methods} in the {Analysis} of {Graphical} {Structures}},
	year = {2006}}

