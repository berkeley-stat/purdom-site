	issn = {0028-0836},
	journal = {Nature},
	keywords = {collaborative, sinceTenure},
	month = {3},
	number = {7879},
	pages = {103--110},
	title = {A transcriptomic and epigenomic cell atlas of the mouse primary motor cortex},
