	file = {PDF:/Users/epurdom/Documents/PapersPdfs/Zotero/storage/YP8BLMYT/Verhaak et al._Cancer Cell_2010_Integrated genomic analysis identifies clinically relevant subtypes of glioblastoma characterized by abn.pdf:application/pdf},
	journal = {Cancer Cell},
	keywords = {collaborative},
	month = {1},
	number = {1},
	pages = {98--110},
	title = {Integrated genomic analysis identifies clinically relevant subtypes of glioblastoma characterized by abnormalities in {PDGFRA}, {IDH1}, {EGFR}, and {NF1}},
