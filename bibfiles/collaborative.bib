	author = {Cook, Christopher P. and Taylor, Mark and Liu, Yale and Schmidt, Ralf and Sedgewick, Andrew and Kim, Esther and Hailer, Ashley and North, Jeffrey P. and Harirchian, Paymann and Wang, Hao and Kashem, Sakeen W. and Shou, Yanhong and McCalmont, Timothy C. and Benz, Stephen C. and Choi, Jaehyuk and Purdom, Elizabeth and Marson, Alexander and Ramos, Silvia B. V. and Cheng, Jeffrey B. and Cho, Raymond J.},
